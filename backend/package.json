{
  "name": "gaming-cafe-backend",
  "version": "1.0.0",
  "description": "Backend API for internet cafe management system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "seed:admin": "npx ts-node src/scripts/seedDatabase.ts --admin-only",
    "seed:all": "npx ts-node src/scripts/seedDatabase.ts",
    "seed:fresh": "npx ts-node src/scripts/seedDatabase.ts --drop",
    "db:indexes": "npx ts-node src/scripts/seedDatabase.ts --indexes-only"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "compression": "^1.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/express-http-proxy": "^1.6.6",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.2.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8"
  }
}
