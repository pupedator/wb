# Backend Environment Configuration
# Copy this file to .env and update with your actual values

# =================================
# Server Configuration
# =================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# =================================
# Database Configuration
# =================================
# MongoDB Atlas (Cloud) - Your actual connection
MONGODB_URI=mongodb+srv://kamal:SOBACHKA2007m_@cluster0.eejhkev.mongodb.net/gamingcafe?retryWrites=true&w=majority&appName=Cluster0
DB_NAME=gamingcafe

# Local MongoDB (development fallback)
# MONGODB_URI=mongodb://localhost:27017/gamingcafe

# =================================
# JWT Configuration
# =================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRY=24h
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# =================================
# Security Configuration
# =================================
BCRYPT_ROUNDS=12

# =================================
# Rate Limiting
# =================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# Email Configuration (for OTP)
# =================================
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@gamingcafe.com

# =================================
# Redis Configuration (Optional)
# =================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =================================
# Cloud Storage (Optional)
# =================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=gamingcafe-uploads

# =================================
# Logging Configuration
# =================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
