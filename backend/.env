# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pixelcyberzone
DB_NAME=pixelcyberzone

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=pixelcyberzone_super_secure_jwt_secret_key_for_development_2024
JWT_EXPIRY=24h

# Email Configuration (for OTP) - Leave empty for development mode
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
